# =========================================================================
# brapi.dev — cotações de moedas, ações, futuros (café arábica)
# =========================================================================
# Pega em https://brapi.dev (dashboard após assinar PRO)
BRAPI_TOKEN=

# =========================================================================
# Z-API — gateway de WhatsApp
# =========================================================================
# Painel: https://app.z-api.io
# Cria uma instância, escaneia o QR code, e pega:
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
# Client-Token: Settings → Conta → Security (token único da conta)
ZAPI_CLIENT_TOKEN=

# =========================================================================
# App
# =========================================================================
# URL pública pra Z-API saber pra onde mandar webhooks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret partilhado entre Edge Functions e API routes
# Gera um valor aleatório: openssl rand -hex 32
EDGE_FUNCTION_SECRET=
