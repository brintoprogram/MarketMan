# =========================================================================
# Z-API — WhatsApp (3 valores diferentes, atenção!)
# =========================================================================
# Painel: https://app.z-api.io
# Cria 1 instância, escaneia QR; depois pega:
#   - Instance ID: na lista de instâncias (campo "ID")
#   - Instance Token: na mesma tela (campo "Token")
zapi_instance_id=
zapi_instance_token=
# Client-Token: vai em "Conta" → "Segurança" (token único da sua conta Z-API)
zapi_client_token=

